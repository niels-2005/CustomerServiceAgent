# API
API_HOST="0.0.0.0"
API_PORT="8000"
API_MAX_USER_MESSAGE_LENGTH="500"
API_CORS_ALLOW_ORIGINS='["http://127.0.0.1:3000","http://localhost:3000","http://127.0.0.1:5173","http://localhost:5173"]'
API_CORS_ALLOW_CREDENTIALS="false"
API_CORS_ALLOW_METHODS='["GET","POST"]'
API_CORS_ALLOW_HEADERS='["Content-Type","X-Request-ID"]'
API_TRUSTED_HOSTS='["127.0.0.1","localhost","testserver"]'
API_CHAT_RATE_LIMIT="10/minute"

# Provider selector
LLM_PROVIDER="ollama" # ollama | openai | gemini | openrouter
EMBEDDING_PROVIDER="ollama" # ollama | openai | gemini

# Provider API keys
OPENAI_API_KEY=""
GOOGLE_API_KEY=""
OPENROUTER_API_KEY=""

# LLM Ollama Section (is only used if LLM_PROVIDER=ollama)
OLLAMA_CHAT_MODEL="qwen3.5:9b"
# Optional knobs: uncomment to override SDK defaults; keep commented to use SDK defaults.
# OLLAMA_BASE_URL="http://localhost:11434" # Custom Ollama host URL.
# OLLAMA_REQUEST_TIMEOUT_SECONDS="360" # Request timeout in seconds.
# OLLAMA_THINKING="high" # Thinking mode override; use true/false or low|medium|high if supported.
# OLLAMA_CONTEXT_WINDOW="8000" # Max input context tokens override.
# OLLAMA_TEMPERATURE="0.2" # Sampling temperature: lower = more deterministic answers.
# OLLAMA_PROMPT_KEY="prompt" # Field name used to send prompt text to Ollama.
# OLLAMA_JSON_MODE="false" # Force JSON response mode if your workflow expects JSON.
# OLLAMA_KEEP_ALIVE="10m" # Keep model loaded in memory for this duration.

# LLM OpenAI Section (is only used if LLM_PROVIDER=openai)
OPENAI_LLM_MODEL="gpt-4o-mini"
# Optional knobs: uncomment to override SDK defaults; keep commented to use SDK defaults.
# OPENAI_LLM_TEMPERATURE="0.2" # Sampling temperature: lower = more deterministic answers.
# OPENAI_LLM_MAX_TOKENS="512" # Hard output token cap for each response.
# OPENAI_LLM_MAX_RETRIES="3" # Retry count for transient API failures.
# OPENAI_LLM_TIMEOUT_SECONDS="60" # Request timeout in seconds.
# OPENAI_LLM_API_BASE="" # Custom OpenAI-compatible base URL endpoint.
# OPENAI_LLM_API_VERSION="" # API version override (mainly for compatibility setups).
# OPENAI_LLM_STRICT="false" # Enforce strict tool/structured output behavior.
# OPENAI_LLM_REASONING_EFFORT="low" # none|minimal|low|medium|high|xhigh.

# LLM Gemini Section (is only used if LLM_PROVIDER=gemini)
GEMINI_LLM_MODEL="gemini-2.5-flash"
# Optional knobs: uncomment to override SDK defaults; keep commented to use SDK defaults.
# GEMINI_LLM_TEMPERATURE="0.2" # Sampling temperature for response creativity.
# GEMINI_LLM_MAX_TOKENS="512" # Hard output token cap for each response.
# GEMINI_LLM_CONTEXT_WINDOW="32000" # Input context limit override for supported models.
# GEMINI_LLM_MAX_RETRIES="3" # Retry count for transient API failures.
# GEMINI_LLM_CACHED_CONTENT="" # Reuse an existing cached content handle.
# GEMINI_LLM_FILE_MODE="hybrid" # inline|fileapi|hybrid file handling mode.

# LLM OpenRouter Section (is only used if LLM_PROVIDER=openrouter)
OPENROUTER_LLM_MODEL="mistralai/mixtral-8x7b-instruct"
# Optional knobs: uncomment to override SDK defaults; keep commented to use SDK defaults.
# OPENROUTER_TEMPERATURE="0.2" # Sampling temperature for response creativity.
# OPENROUTER_MAX_TOKENS="512" # Hard output token cap for each response.
# OPENROUTER_CONTEXT_WINDOW="4096" # Max input context tokens; if commented, model/provider default is used.
# OPENROUTER_MAX_RETRIES="5" # Retry count for transient API failures.
# OPENROUTER_API_BASE="https://openrouter.ai/api/v1" # Custom OpenRouter-compatible base URL.
# OPENROUTER_ALLOW_FALLBACKS="true" # Allow fallback providers/routes when available.

# Embedding Ollama Section (is only used if EMBEDDING_PROVIDER=ollama)
OLLAMA_EMBEDDING_MODEL="qwen3-embedding:0.6b"
# Optional knobs: uncomment to override SDK defaults; keep commented to use SDK defaults.
# OLLAMA_EMBEDDING_BATCH_SIZE="10" # Number of texts embedded per batch request.
# OLLAMA_EMBEDDING_KEEP_ALIVE="10m" # Keep embedding model loaded in memory.
# OLLAMA_EMBEDDING_QUERY_INSTRUCTION="" # Prefix instruction applied to query embeddings.
# OLLAMA_EMBEDDING_TEXT_INSTRUCTION="" # Prefix instruction applied to document embeddings.
# OLLAMA_EMBEDDING_NUM_CTX="2048" # num_ctx passed via Ollama additional kwargs.

# Embedding OpenAI Section (is only used if EMBEDDING_PROVIDER=openai)
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
# Optional knobs: uncomment to override SDK defaults; keep commented to use SDK defaults.
# OPENAI_EMBEDDING_MODE="text_search" # Embedding mode (e.g., text_search/similarity).
# OPENAI_EMBEDDING_BATCH_SIZE="100" # Number of texts embedded per batch request.
# OPENAI_EMBEDDING_DIMENSIONS="1536" # Output vector dimensions (model-dependent).
# OPENAI_EMBEDDING_MAX_RETRIES="10" # Retry count for transient API failures.
# OPENAI_EMBEDDING_TIMEOUT_SECONDS="60" # Request timeout in seconds.
# OPENAI_EMBEDDING_API_BASE="" # Custom OpenAI-compatible base URL endpoint.
# OPENAI_EMBEDDING_API_VERSION="" # API version override (mainly for compatibility setups).
# OPENAI_EMBEDDING_NUM_WORKERS="4" # Parallel worker count for batch embedding.

# Embedding Gemini Section (is only used if EMBEDDING_PROVIDER=gemini)
GEMINI_EMBEDDING_MODEL="gemini-embedding-2-preview"
# Optional knobs: uncomment to override SDK defaults; keep commented to use SDK defaults.
# GEMINI_EMBEDDING_BATCH_SIZE="10" # Number of texts embedded per batch request.
# GEMINI_EMBEDDING_RETRIES="3" # Retry count for transient API failures.
# GEMINI_EMBEDDING_TIMEOUT_SECONDS="60" # Request timeout in seconds.
# GEMINI_EMBEDDING_RETRY_MIN_SECONDS="1" # Minimum backoff delay between retries.
# GEMINI_EMBEDDING_RETRY_MAX_SECONDS="60" # Maximum backoff delay between retries.
# GEMINI_EMBEDDING_RETRY_EXPONENTIAL_BASE="2" # Exponential retry growth factor.

# Chroma defaults + corpus
CHROMA_PERSIST_DIR=".chroma"
CHROMA_COLLECTION_NAME="customer_bot_faq"
CORPUS_CSV_PATH="dataset/corpus.csv"
TEXT_INGESTION_MODE="question_only" # question_only | question_answer | answer_only

# Retrieval + memory
RETRIEVAL_TOP_K="1"
SIMILARITY_CUTOFF="0.6"
MEMORY_MAX_TURNS="10"
AGENT_DESCRIPTION="Agent for FAQ-only customer support responses"
AGENT_SYSTEM_PROMPT="You are a customer support FAQ assistant. Use the faq_lookup tool whenever you need new FAQ information to answer the user's message. The tool returns JSON with matches where each item has faq_id, answer, and score. Write a concise German answer using only information grounded in tool results"
NO_MATCH_INSTRUCTION="If faq_lookup returns an empty matches list, explain in German that you could not find reliable information in the FAQs."
FAQ_TOOL_DESCRIPTION="Find top FAQ matches for a user question after similarity filtering. Returns JSON with a matches list containing faq_id, answer, and score."
AGENT_TIMEOUT_SECONDS="500"
ERROR_FALLBACK_TEXT="Aktuell konnte ich die Informationen nicht zuverlässig abrufen, bitte später erneut versuchen oder den Support kontaktieren."

# Langfuse
LANGFUSE_SECRET_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_HOST="http://localhost:3000"
LANGFUSE_TRACING_ENVIRONMENT="default"
LANGFUSE_RELEASE=""
LANGFUSE_FAIL_FAST="true"
