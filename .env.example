# OpenAI is only needed when the backend actually uses the OpenAI provider.
# If you run Ollama-only, this can stay empty.
OPENAI_API_KEY=""

# Optional: set this when you use a newer OpenAI model name that LlamaIndex
# does not yet know internally. It keeps chat memory sizing explicit.
LLM__OPENAI__CONTEXT_WINDOW="400000"

# Langfuse uses a public/secret key pair for trace ingestion from the backend.
# These are only relevant when tracing is enabled and the configured Langfuse host is reachable.
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""

# The React/Vite frontend reads this from the repo-root `.env` during dev/build.
# Point it at the FastAPI base URL that the browser should call.
# For local development that is usually the backend on port 8000.
VITE_API_BASE_URL="http://127.0.0.1:8000"

# Required Redis for shared API rate limiting across processes/containers.
# Example uses Redis DB `/1` so rate-limit keys stay separate from other local Redis consumers.
# The DB number is only an operational separation for clarity, not a security boundary.
# Keep the password placeholder aligned with your local or deployed Redis auth.
RATE_LIMIT_REDIS_URL="redis://:myredissecret@127.0.0.1:6379/1"

# Required Redis for short-term chat memory with TTL-based cleanup.
# Example uses Redis DB `/2` so chat-history keys stay isolated from Langfuse/local Redis usage
# and from rate limiting on `/1`, which makes inspection and cleanup easier.
# The DB number is again just a practical separation choice for operators.
CHAT_MEMORY_REDIS_URL="redis://:myredissecret@127.0.0.1:6379/2"

# Langfuse host is currently kept explicit for local development transparency.
# Change this only if your Langfuse instance is not running at the default local URL.
LANGFUSE_HOST="http://localhost:3000"
