# API
API_HOST="0.0.0.0"
API_PORT="8000"

# Ollama
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_CHAT_MODEL="qwen3.5:9b"
OLLAMA_EMBEDDING_MODEL="qwen3-embedding:0.6b"
OLLAMA_REQUEST_TIMEOUT_SECONDS="360"
OLLAMA_THINKING="true"
OLLAMA_CONTEXT_WINDOW="8000"
OLLAMA_KEEP_ALIVE="10m"
OLLAMA_EMBEDDING_NUM_CTX="2048"

# Chroma + corpus
CHROMA_PERSIST_DIR=".chroma"
CHROMA_COLLECTION_NAME="customer_bot_faq"
CORPUS_CSV_PATH="dataset/corpus.csv"
TEXT_INGESTION_MODE="question_only" # question_only | question_answer | answer_only

# Retrieval + memory
RETRIEVAL_TOP_K="3"
SIMILARITY_CUTOFF="0.6"
MEMORY_MAX_TURNS="10"
FALLBACK_TEXT="Dazu habe ich in unseren FAQs aktuell keine verlässliche Information. Bitte kontaktiere den Support direkt."

# Langfuse
LANGFUSE_SECRET_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_HOST="http://localhost:3000"
LANGFUSE_FAIL_FAST="true"
