# Secrets
OPENAI_API_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""

# Frontend (Vite reads these from the repo root .env)
VITE_API_BASE_URL="http://127.0.0.1:8000"

# Optional runtime overrides
# Keep these commented unless you want to override the YAML defaults in
# `src/customer_bot/config/defaults/`.

# API__HOST="0.0.0.0"
# API__PORT="8000"
# API__RATE_LIMIT__DEFAULT_LIMIT="60/minute"
# API__RATE_LIMIT__CHAT_LIMIT="10/minute"
# API__RATE_LIMIT__STORAGE_URI="redis://:myredissecret@127.0.0.1:6379/1"
# API__RATE_LIMIT__KEY_PREFIX="customer-bot:ratelimit"
# API__RATE_LIMIT__TRUST_PROXY_HEADERS="false"

# Provider/runtime endpoints
# LLM__OLLAMA__BASE_URL="http://localhost:11434"
LANGFUSE_HOST="http://localhost:3000"

# Local storage / data paths
# STORAGE__CHROMA_PERSIST_DIR=".chroma"
# INGESTION__FAQ__CORPUS_CSV_PATH="dataset/corpus.csv"
# INGESTION__PRODUCTS__CORPUS_CSV_PATH="dataset/products.csv"
# STORAGE__FAQ__COLLECTION_NAME="customer_bot_faq"
# STORAGE__PRODUCTS__COLLECTION_NAME="customer_bot_products"
